{
  "name": "@armengabrielyan/autoloop",
  "version": "0.1.3",
  "description": "npm package for the AutoLoop CLI. Installs the `autoloop` command for agent-agnostic optimization loops.",
  "repository": {
    "type": "git",
    "url": "https://github.com/armgabrielyan/autoloop.git"
  },
  "author": "Armen Gabrielyan",
  "license": "MIT",
  "keywords": [
    "autoloop",
    "cli",
    "agents",
    "automation",
    "optimization"
  ],
  "bin": {
    "autoloop": "bin/autoloop"
  },
  "scripts": {
